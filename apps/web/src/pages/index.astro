---
import { Image } from "astro:assets";
import StemToy from "../components/StemToy.astro";
import "../styles/global.css";

import shotStudio from "../assets/studio.png";
import shotHome from "../assets/home.png";
import shotLyrics from "../assets/studio-lyrics.png";
import shotOutput from "../assets/studio-output.png";

const REPO = "https://github.com/SammitBadodekar/timbrel";
const RELEASES = `${REPO}/releases`;
const TITLE = "Timbrel — turn any song into your backing band";
const DESCRIPTION =
  "Free, open-source desktop studio that splits any song into six stems — vocals, drums, bass, guitar, piano & other. Mute your part, loop the hard bars, bend tempo and key, and play along. Fully local: no cloud, no account, nothing leaves your device.";

const stats = [
  { n: "6", label: "stems from one song" },
  { n: "~30s", label: "to separate a track" },
  { n: "$0", label: "forever · MIT licensed" },
  { n: "0", label: "servers involved" },
];

const faqs = [
  {
    q: "Is it really free?",
    a: "Yes — MIT-licensed open source, no account, no pro tier. Nothing runs on anyone's servers, so there's nothing to charge for.",
  },
  {
    q: "How does the separation work?",
    a: "Demucs (Meta's htdemucs_6s model) runs locally on your GPU or Apple Silicon. YouTube audio arrives via yt-dlp. It stands on excellent open-source shoulders.",
  },
  {
    q: "Which platforms?",
    a: "macOS, Windows and Linux — developed on macOS first. Installers are on the releases page; building from source takes a few commands.",
  },
  {
    q: "Do I need internet?",
    a: "Only for YouTube search and lyrics. Separation, playback and export work fully offline.",
  },
  {
    q: "Is downloading from YouTube allowed?",
    a: "Timbrel is a practice tool — like a smarter record player. Stick to content you have the rights to use, and support the artists you practice to.",
  },
  {
    q: "Where do my files live?",
    a: "In plain folders on your disk: FLAC stems and a small local database. Delete the app and your music is still just files.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://timbrel.samz.in/" />
    <meta name="theme-color" content="#ebf5ff" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:url" content="https://timbrel.samz.in/" />
    <meta property="og:image" content="https://timbrel.samz.in/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preload" href="/fonts/GeistVF.woff" as="font" type="font/woff" crossorigin />
  </head>

  <body>
    <!-- ================= NAV ================= -->
    <header class="wrap nav">
      <a class="brand" href="#top">
        <i>
          <svg width="14" height="14" viewBox="0 0 16 16" aria-hidden="true">
            <rect x="1.9" y="5" width="2" height="6" rx="1" fill="#e8446d"></rect>
            <rect x="5.3" y="3.75" width="2" height="8.5" rx="1" fill="#e08a00"></rect>
            <rect x="8.7" y="2.5" width="2" height="11" rx="1" fill="#7c5cff"></rect>
            <rect x="12.1" y="3.5" width="2" height="9" rx="1" fill="#0da678"></rect>
          </svg>
        </i>
        Timbrel
      </a>
      <nav class="nav-links">
        <a href="#studio">Studio</a>
        <a href="#features">Features</a>
        <a href="#faq">FAQ</a>
      </nav>
      <div class="nav-cta">
        <a class="pill pill-ghost gh" href={REPO}>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
            ></path>
          </svg>
          GitHub
        </a>
        <a class="pill pill-dark" href={RELEASES}>Download</a>
      </div>
    </header>

    <main id="top">
      <!-- ================= HERO ================= -->
      <section class="wrap hero">
        <div class="hero-badges">
          <span class="chip mint">Free forever</span>
          <span class="chip lav">Open source</span>
          <span class="chip powder">100% on your device</span>
        </div>
        <h1>Turn any song into <em>your backing band</em>.</h1>
        <p class="lede hero-lede">Six stems out of any track. Mute your part, loop the hard bars, play along.</p>
        <div class="hero-cta">
          <a class="pill pill-dark" href={RELEASES}>Download for free</a>
          <a class="pill pill-ghost" href={REPO}>
            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path
                d="M8 .8l2.18 4.42 4.88.71-3.53 3.44.83 4.86L8 11.94l-4.36 2.29.83-4.86L.94 5.93l4.88-.71L8 .8z"
              ></path>
            </svg>
            Star on GitHub
          </a>
        </div>
        <div class="hero-toy">
          <StemToy />
        </div>
      </section>

      <!-- ================= STUDIO MEGA-BANNER ================= -->
      <section class="wrap section" id="studio">
        <div class="mega">
          <div class="mega-head">
            <h2>This is the studio.</h2>
            <p>Every stem on its own lane — mute, solo, loop, bend.</p>
          </div>
          <div class="mega-shot">
            <span class="float-chip chip solar num">≈ 30 sec per song</span>
            <span class="float-chip chip mint right">BPM &amp; key detected</span>
            <Image
              src={shotStudio}
              alt="Timbrel's studio: six colored stem lanes with waveforms, mute/solo and volume per stem, and a floating transport dock with tempo, key, loop, click and count-in controls"
              widths={[760, 1240, 1800, 2400]}
              sizes="(max-width: 1200px) 94vw, 1040px"
              format="webp"
              quality={82}
              loading="lazy"
            />
          </div>
          <div class="mega-chips">
            <span class="chip" style="background: var(--stem-vocals-wash)"
              ><span class="dot" style="background: var(--stem-vocals)"></span>Vocals</span
            >
            <span class="chip" style="background: var(--stem-drums-wash)"
              ><span class="dot" style="background: var(--stem-drums)"></span>Drums</span
            >
            <span class="chip" style="background: var(--stem-bass-wash)"
              ><span class="dot" style="background: var(--stem-bass)"></span>Bass</span
            >
            <span class="chip" style="background: var(--stem-guitar-wash)"
              ><span class="dot" style="background: var(--stem-guitar)"></span>Guitar</span
            >
            <span class="chip" style="background: var(--stem-piano-wash)"
              ><span class="dot" style="background: var(--stem-piano)"></span>Piano</span
            >
            <span class="chip" style="background: var(--stem-other-wash)"
              ><span class="dot" style="background: var(--stem-other)"></span>Other</span
            >
          </div>
        </div>
      </section>

      <!-- ================= STATS ================= -->
      <section class="wrap section-sm">
        <div class="stats">
          {
            stats.map((s) => (
              <div class="stat">
                <span class="stat-n num">{s.n}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))
          }
        </div>
      </section>

      <!-- ================= FEATURES ================= -->
      <section class="wrap section" id="features">
        <h2>Everything you need to woodshed.</h2>
        <div class="cards">
          <!-- search -->
          <article class="card">
            <div class="card-art" style="background: var(--wash-solar)">
              <div class="art-img top">
                <Image
                  src={shotHome}
                  alt="Timbrel's home screen: a YouTube search omnibox, playlist cards and a track list with BPM and key chips"
                  widths={[560, 900, 1400]}
                  sizes="(max-width: 860px) 94vw, 520px"
                  format="webp"
                  quality={82}
                  loading="lazy"
                />
              </div>
            </div>
            <div class="card-copy">
              <h3>Search YouTube, or drop a file</h3>
              <p>One box. Type a song — it lands in your library, already separated.</p>
            </div>
          </article>

          <!-- lyrics -->
          <article class="card">
            <div class="card-art" style="background: var(--wash-lavender)">
              <div class="art-img right">
                <Image
                  src={shotLyrics}
                  alt="The studio with a synced lyrics panel open, showing the words to Viva La Vida"
                  widths={[560, 900, 1400]}
                  sizes="(max-width: 860px) 94vw, 520px"
                  format="webp"
                  quality={82}
                  loading="lazy"
                />
              </div>
            </div>
            <div class="card-copy">
              <h3>Lyrics that follow along</h3>
              <p>Synced words, karaoke-style. Mute the vocals — the mic is yours.</p>
            </div>
          </article>

          <!-- practice tools (CSS mock) -->
          <article class="card">
            <div class="card-art center" style="background: var(--wash-mint)">
              <div class="dock-mock" aria-hidden="true">
                <span class="dock-play">
                  <svg width="12" height="12" viewBox="0 0 14 14" fill="#fff">
                    <path d="M3.4 1.8c0-.9 1-1.5 1.8-1L12 5.9c.8.5.8 1.7 0 2.2l-6.8 5.1c-.8.5-1.8-.1-1.8-1V1.8z"
                    ></path>
                  </svg>
                </span>
                <span class="mock-pill num">Tempo 140 <b>→ 96</b></span>
                <span class="mock-pill num">Key <b>+2 st</b></span>
                <span class="mock-pill loop num">Loop <b>bars 17–20</b></span>
                <span class="mock-pill num">Click · Count-in</span>
              </div>
            </div>
            <div class="card-copy">
              <h3>Practice tools that count you in</h3>
              <p>Loop the hard part, slow it down, move it to your key.</p>
            </div>
          </article>

          <!-- routing -->
          <article class="card">
            <div class="card-art" style="background: var(--wash-peach)">
              <div class="art-img center">
                <Image
                  src={shotOutput}
                  alt="The audio output panel: three output devices and per-stem routing rules"
                  widths={[560, 900, 1400]}
                  sizes="(max-width: 860px) 94vw, 520px"
                  format="webp"
                  quality={82}
                  loading="lazy"
                />
              </div>
            </div>
            <div class="card-copy">
              <h3>Route stems anywhere</h3>
              <p>Click to the drummer's in-ears, vocals to the singer, the rest to the PA.</p>
            </div>
          </article>

          <!-- setlists (CSS mock) -->
          <article class="card">
            <div class="card-art center" style="background: var(--wash-powder)">
              <div class="pl-mock" aria-hidden="true">
                <div class="pl-mini">
                  <div class="pl-cover">
                    <i style="background: linear-gradient(135deg, var(--wash-solar), var(--wash-peach))"></i>
                    <i style="background: linear-gradient(135deg, var(--wash-powder), #c2e9ff)"></i>
                    <i style="background: linear-gradient(135deg, var(--wash-lavender), #e4ccff)"></i>
                    <i style="background: linear-gradient(135deg, var(--wash-mint), #b8f0d2)"></i>
                  </div>
                  <b>Saturday gig</b>
                  <span class="num">12 tracks · 48 min</span>
                </div>
                <div class="pl-mini">
                  <div class="pl-cover">
                    <i style="background: linear-gradient(135deg, #feefd6, var(--wash-solar))"></i>
                    <i style="background: linear-gradient(135deg, var(--wash-peach), #ffdfcb)"></i>
                    <i style="background: linear-gradient(135deg, var(--wash-mint), #b8f0d2)"></i>
                    <i style="background: linear-gradient(135deg, var(--wash-lavender), var(--wash-powder))"></i>
                  </div>
                  <b>Drum practice</b>
                  <span class="num">4 tracks · 17 min</span>
                </div>
              </div>
            </div>
            <div class="card-copy">
              <h3>Setlists in</h3>
              <p>Playlists for rehearsals and gigs.</p>
            </div>
          </article>

          <!-- export (CSS mock) -->
          <article class="card">
            <div class="card-art center" style="background: var(--wash-lavender)">
              <div class="export-mock" aria-hidden="true">
                <span class="mock-pill">Stems</span>
                <span class="mock-pill">Mixdown</span>
                <span class="mock-pill dark">Minus-one</span>
                <span class="mock-pill">Click track</span>
                <span class="chip mint mono-chip">.flac</span>
              </div>
            </div>
            <div class="card-copy">
              <h3>Stems out</h3>
              <p>Export the mix, your minus-one, or a click track — take it anywhere.</p>
            </div>
          </article>
        </div>
      </section>

      <!-- ================= PRIVACY ================= -->
      <section class="wrap section" id="privacy">
        <div class="manifesto">
          <h2>Nothing leaves your device.</h2>
          <p class="manifesto-line">The AI runs on your GPU, not ours. Your music is FLAC files in folders.</p>
          <div class="manifesto-badges">
            <span class="badge">No cloud</span>
            <span class="badge">No account</span>
            <span class="badge">No telemetry</span>
            <span class="badge">No lock-in</span>
            <span class="badge">Works offline</span>
          </div>
        </div>
      </section>

      <!-- ================= FAQ ================= -->
      <section class="wrap section" id="faq">
        <h2>Fair questions.</h2>
        <div class="faqs">
          {
            faqs.map((f) => (
              <details class="faq">
                <summary>
                  {f.q}
                  <span class="faq-plus" aria-hidden="true">
                    +
                  </span>
                </summary>
                <p>{f.a}</p>
              </details>
            ))
          }
        </div>
      </section>

      <!-- ================= CLOSER ================= -->
      <section class="wrap section">
        <div class="closer">
          <h2>The band is waiting.</h2>
          <p>Any song. Six stems. Your move.</p>
          <div class="closer-cta">
            <a class="pill closer-pill" href={RELEASES}>Download Timbrel</a>
            <a class="pill closer-ghost" href={REPO}>Build from source</a>
          </div>
        </div>
      </section>
    </main>

    <!-- ================= FOOTER ================= -->
    <footer class="wrap footer">
      <div class="footer-brand">
        <a class="brand" href="#top">
          <i>
            <svg width="14" height="14" viewBox="0 0 16 16" aria-hidden="true">
              <rect x="1.9" y="5" width="2" height="6" rx="1" fill="#e8446d"></rect>
              <rect x="5.3" y="3.75" width="2" height="8.5" rx="1" fill="#e08a00"></rect>
              <rect x="8.7" y="2.5" width="2" height="11" rx="1" fill="#7c5cff"></rect>
              <rect x="12.1" y="3.5" width="2" height="9" rx="1" fill="#0da678"></rect>
            </svg>
          </i>
          Timbrel
        </a>
        <span class="footer-note">Made by Sammit Badodekar</span>
      </div>
      <nav class="footer-links">
        <a href={REPO}>
          <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
            ></path>
          </svg>
          Project
        </a>
        <a href="https://github.com/SammitBadodekar">GitHub</a>
        <a href="https://www.linkedin.com/in/sammitbadodekar/">LinkedIn</a>
        <a href={`${REPO}/blob/main/LICENSE`}>MIT License</a>
      </nav>
    </footer>

    <style>
      /* ---------------- nav ---------------- */
      .nav {
        display: flex;
        align-items: center;
        gap: 28px;
        padding-top: 26px;
        padding-bottom: 10px;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-weight: 600;
        font-size: 17px;
        letter-spacing: -0.02em;
      }
      .brand i {
        width: 24px;
        height: 24px;
        border-radius: 8px;
        background: var(--charcoal);
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .nav-links {
        display: flex;
        gap: 22px;
        margin: 0 auto;
        font-size: 14.5px;
        color: var(--graphite);
      }
      .nav-links a:hover {
        color: var(--ink);
      }
      .nav-cta {
        display: flex;
        gap: 10px;
      }
      .nav-cta .pill {
        padding: 9px 20px;
        font-size: 14px;
      }
      @media (max-width: 860px) {
        .nav-links {
          display: none;
        }
        .nav-cta {
          margin-left: auto;
        }
      }
      @media (max-width: 480px) {
        .nav-cta .gh {
          display: none;
        }
      }

      /* ---------------- hero ---------------- */
      .hero {
        padding-top: 68px;
        text-align: center;
      }
      .hero-badges {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 26px;
      }
      h1 {
        font-size: clamp(42px, 7vw, 84px);
        letter-spacing: -0.025em;
        line-height: 1.02;
        max-width: 900px;
        margin: 0 auto;
      }
      h1 em {
        font-style: normal;
        color: var(--iris);
      }
      .hero-lede {
        margin: 22px auto 0;
        max-width: 560px;
      }
      .hero-cta {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 32px;
      }
      .hero-toy {
        margin-top: 60px;
        text-align: left;
      }

      /* ---------------- sections ---------------- */
      .section {
        margin-top: 130px;
      }
      .section-sm {
        margin-top: 56px;
      }
      .section > h2 {
        margin-bottom: 8px;
      }
      .section > .lede {
        margin-bottom: 8px;
      }
      @media (max-width: 720px) {
        .section {
          margin-top: 88px;
        }
      }

      /* ---------------- studio mega-banner ---------------- */
      .mega {
        background: var(--wash-powder);
        border-radius: var(--r-hero);
        padding: clamp(28px, 4.5vw, 56px);
        overflow: hidden;
      }
      .mega-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
        margin-bottom: 28px;
      }
      .mega-head p {
        color: var(--graphite);
        font-size: 15.5px;
        margin: 0;
      }
      .mega-shot {
        position: relative;
      }
      .mega-shot img {
        width: 100%;
        height: auto;
        border-radius: var(--r-frame);
        border: 1px solid rgba(10, 13, 18, 0.08);
        box-shadow: var(--shadow-frame);
      }
      .float-chip {
        position: absolute;
        top: -14px;
        left: 22px;
        z-index: 2;
        box-shadow: 0 10px 20px -10px rgba(4, 69, 144, 0.4);
      }
      .float-chip.right {
        left: auto;
        right: 22px;
      }
      .mega-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: center;
        margin-top: 26px;
      }

      /* ---------------- stats ---------------- */
      .stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
      }
      @media (max-width: 860px) {
        .stats {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      .stat {
        background: var(--bone);
        border: 1px solid var(--border);
        border-radius: var(--r-card);
        padding: 24px 26px;
        text-align: center;
      }
      .stat-n {
        display: block;
        font-size: clamp(34px, 4vw, 46px);
        font-weight: 500;
        letter-spacing: -0.025em;
        line-height: 1.1;
      }
      .stat-label {
        color: var(--fog);
        font-size: 13.5px;
        font-weight: 600;
      }

      /* ---------------- feature cards ---------------- */
      .cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
        margin-top: 32px;
      }
      @media (max-width: 860px) {
        .cards {
          grid-template-columns: 1fr;
        }
      }
      .card {
        background: var(--bone);
        border: 1px solid var(--border);
        border-radius: var(--r-frame);
        overflow: hidden;
        transition:
          transform 0.25s cubic-bezier(0.16, 1, 0.3, 1),
          box-shadow 0.25s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-float);
      }
      .card-art {
        height: 240px;
        position: relative;
        overflow: hidden;
      }
      .card-art.center {
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .art-img {
        position: absolute;
        inset: 16px 16px 0;
        border-radius: 14px 14px 0 0;
        overflow: hidden;
        border: 1px solid rgba(10, 13, 18, 0.08);
        border-bottom: 0;
        box-shadow: 0 18px 34px -18px rgba(4, 69, 144, 0.35);
      }
      .art-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .art-img.top img {
        object-position: center top;
      }
      .art-img.right img {
        object-position: right center;
      }
      .art-img.center img {
        object-position: center;
      }
      .card-copy {
        padding: 20px 24px 22px;
      }
      .card-copy h3 {
        font-size: 17px;
        font-weight: 600;
        letter-spacing: -0.015em;
        margin: 0 0 5px;
      }
      .card-copy p {
        color: var(--graphite);
        font-size: 14px;
        line-height: 1.5;
        margin: 0;
      }

      /* CSS mocks inside cards */
      .dock-mock {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        justify-content: center;
        gap: 8px;
        background: var(--paper);
        border: 1px solid var(--border);
        border-radius: 9999px;
        padding: 10px 18px 10px 10px;
        box-shadow: var(--shadow-float);
        margin: 0 18px;
      }
      .dock-play {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: var(--charcoal);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: none;
      }
      .dock-play svg {
        margin-left: 2px;
      }
      .mock-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        border-radius: 9999px;
        padding: 6px 13px;
        font-size: 12.5px;
        font-weight: 500;
        color: var(--graphite);
        background: var(--paper);
        border: 1px solid var(--border);
        white-space: nowrap;
      }
      .mock-pill b {
        color: var(--ink);
        font-weight: 600;
      }
      .mock-pill.loop {
        background: rgba(0, 105, 224, 0.08);
        color: var(--iris);
        border-color: rgba(0, 105, 224, 0.25);
      }
      .mock-pill.loop b {
        color: var(--iris);
      }
      .mock-pill.dark {
        background: var(--charcoal);
        color: #fff;
        border-color: var(--charcoal);
      }

      .pl-mock {
        display: flex;
        gap: 16px;
      }
      .pl-mini {
        background: var(--bone);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 10px;
        width: 150px;
        box-shadow: var(--shadow-float);
      }
      .pl-mini .pl-cover {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 1fr 1fr;
        gap: 2px;
        border-radius: 10px;
        overflow: hidden;
        aspect-ratio: 1.5 / 1;
      }
      .pl-mini b {
        display: block;
        font-size: 12.5px;
        font-weight: 600;
        margin-top: 8px;
        letter-spacing: -0.01em;
      }
      .pl-mini span {
        color: var(--fog);
        font-size: 11px;
      }

      .export-mock {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
        gap: 8px;
        padding: 0 26px;
      }
      .export-mock .mock-pill {
        font-size: 13.5px;
        padding: 8px 16px;
      }
      .mono-chip {
        font-family: var(--mono);
        letter-spacing: 0;
      }

      /* ---------------- privacy ---------------- */
      .manifesto {
        background: var(--charcoal);
        color: #fff;
        border-radius: var(--r-hero);
        padding: clamp(36px, 6vw, 68px);
        text-align: center;
        box-shadow: 0 40px 80px -40px rgba(10, 13, 18, 0.5);
      }
      .manifesto h2 {
        color: #fff;
      }
      .manifesto-line {
        color: rgba(255, 255, 255, 0.65);
        font-size: 16px;
        margin: 14px auto 0;
        max-width: 460px;
      }
      .manifesto-badges {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px;
        margin-top: 28px;
      }
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border-radius: 9999px;
        padding: 9px 18px;
        font-size: 13.5px;
        font-weight: 600;
        color: #fff;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.14);
      }
      .badge::before {
        content: "";
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--wash-mint) url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 10 10"><path d="M1.5 5.2l2.3 2.3 4.7-4.8" stroke="%230a0d12" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>')
          center / 8px no-repeat;
      }

      /* ---------------- FAQ ---------------- */
      .faqs {
        margin-top: 28px;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .faq {
        background: var(--bone);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 0 24px;
      }
      .faq summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        list-style: none;
        cursor: pointer;
        padding: 18px 0;
        font-weight: 600;
        font-size: 15.5px;
        letter-spacing: -0.01em;
      }
      .faq summary::-webkit-details-marker {
        display: none;
      }
      .faq-plus {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        border: 1px solid var(--border);
        background: var(--paper);
        color: var(--graphite);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        font-weight: 500;
        flex: none;
        transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .faq[open] .faq-plus {
        transform: rotate(45deg);
        background: var(--charcoal);
        border-color: var(--charcoal);
        color: #fff;
      }
      .faq > p {
        color: var(--graphite);
        font-size: 14.5px;
        line-height: 1.6;
        margin: 0;
        padding: 0 0 20px;
      }

      /* ---------------- closer ---------------- */
      .closer {
        background: var(--charcoal);
        color: #fff;
        border-radius: var(--r-hero);
        padding: clamp(44px, 7vw, 88px) 32px;
        text-align: center;
        box-shadow: 0 40px 80px -40px rgba(10, 13, 18, 0.5);
      }
      .closer h2 {
        color: #fff;
        font-size: clamp(34px, 5vw, 56px);
      }
      .closer p {
        color: rgba(255, 255, 255, 0.65);
        margin: 12px 0 0;
        font-size: 16px;
      }
      .closer-cta {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 30px;
      }
      .closer-pill {
        background: #fff;
        color: var(--ink);
      }
      .closer-pill:hover {
        transform: translateY(-1px);
        box-shadow: 0 10px 24px -10px rgba(0, 0, 0, 0.5);
      }
      .closer-ghost {
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.25);
      }
      .closer-ghost:hover {
        border-color: rgba(255, 255, 255, 0.5);
      }

      /* ---------------- footer ---------------- */
      .footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
        padding-top: 80px;
        padding-bottom: 44px;
      }
      .footer-brand {
        display: flex;
        align-items: center;
        gap: 16px;
      }
      .footer-note {
        color: var(--fog);
        font-size: 13.5px;
      }
      .footer-links {
        display: flex;
        align-items: center;
        gap: 20px;
        font-size: 14px;
        color: var(--graphite);
      }
      .footer-links a {
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }
      .footer-links a:hover {
        color: var(--ink);
      }
    </style>
  </body>
</html>
